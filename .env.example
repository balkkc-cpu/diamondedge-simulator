# PostgreSQL (Neon, Vercel Postgres, Supabase). On Windows PowerShell paste your URL in quotes:
# DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"
DATABASE_URL=""
# Required for correct email verification links in production (no trailing slash).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Auth email (Resend). Optional: if RESEND_API_KEY is unset, new accounts are verified immediately and the user is signed in (no inbox step). Add Resend when you want verify-by-email.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="DiamondEdge <onboarding@resend.dev>"
# Owner inbox: signup + community post alerts (comma-separated ok). Requires RESEND_API_KEY in production.
OWNER_NOTIFY_EMAIL="balkkc@gmail.com"
AUTH_SECRET="use-a-long-random-string-in-production"

# Optional API keys (app uses fallback mock data if missing)
# The Odds API (bookmakers=fanduel) — public board prices, cached ~10 min server-side; bet builder also refetches every 10 min.
ODDS_API_KEY=""
SPORTSDATAIO_API_KEY=""
OPENWEATHER_API_KEY=""

# Optional future feeds
NEWS_API_KEY=""
LIVE_SCORE_API_KEY=""

# Owner-only admin login credentials
ADMIN_USERNAME="owner"
ADMIN_PASSWORD_HASH=""
AUTH_SECRET=""

# Creator donation links (your accounts only)
NEXT_PUBLIC_PAYPAL_DONATION_URL="https://www.paypal.com/cgi-bin/webscr?cmd=_donations&business=lecture423%40gmail.com&currency_code=USD"
