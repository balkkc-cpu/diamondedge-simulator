# PostgreSQL (Neon, Vercel Postgres, Supabase). On Windows PowerShell paste your URL in quotes:
# DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"
DATABASE_URL=""
# Required for correct email verification links in production (no trailing slash).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Auth email (Resend). Optional: if RESEND_API_KEY is unset, new accounts are verified immediately and the user is signed in (no inbox step). Add Resend when you want verify-by-email.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="DiamondEdge <onboarding@resend.dev>"
# Owner inbox: signup + community post alerts (comma-separated ok). Requires RESEND_API_KEY in production.
OWNER_NOTIFY_EMAIL="balkkc@gmail.com"
AUTH_SECRET="use-a-long-random-string-in-production"

# Optional API keys (app uses fallback mock data if missing)
# The Odds API — optional extra book depth when ODDS_PROVIDER is not `rundown`. If the key is set but the API
# returns no events (quota/credits), the app falls back to model lines + model props instead of an empty board.
# For free retail lines + player props, use ODDS_PROVIDER=rundown + RUNDOWN_API_KEY and leave ODDS_API_KEY blank.
ODDS_API_KEY=""
# Seconds between Odds API refetches (Next ISR). Default 86400 (24h) to minimize billed requests.
# ODDS_CACHE_SECONDS=86400
# Comma-separated bookmaker keys for per-event player-prop fetches (see The Odds API docs).
# ODDS_EVENT_BOOKMAKERS="fanduel,draftkings,betmgm"
SPORTSDATAIO_API_KEY=""
OPENWEATHER_API_KEY=""

# Optional future feeds
NEWS_API_KEY=""
LIVE_SCORE_API_KEY=""

# Owner-only admin login credentials
ADMIN_USERNAME="owner"
ADMIN_PASSWORD_HASH=""
AUTH_SECRET=""

# Creator donation links (your accounts only)
NEXT_PUBLIC_PAYPAL_DONATION_URL="https://www.paypal.com/cgi-bin/webscr?cmd=_donations&business=lecture423%40gmail.com&currency_code=USD"
NEXT_PUBLIC_VENMO_DONATION_URL="https://venmo.com/lecture423"
NEXT_PUBLIC_CARD_DONATION_URL=""

# The Rundown (therundown.io) — set ODDS_PROVIDER=rundown to use for Bet Builder + coach
# Either name works; requests use header X-TheRundown-Key per https://docs.therundown.io/authentication
RUNDOWN_API_KEY=""
# THERUNDOWN_API_KEY=""
# 3 = MLB (see https://docs.therundown.io/reference/sports.md)
RUNDOWN_SPORT_ID="3"
# Optional: comma-separated affiliate (sportsbook) IDs — see https://docs.therundown.io/reference/sportsbooks.md
# RUNDOWN_AFFILIATE_IDS="19,23"
# Bet Builder: one line per side, prefer these Rundown affiliate ids (order = priority). Default 19,23.
# RUNDOWN_PREFERRED_AFFILIATE_IDS="19,23"
# Game-line chips: default moneyline,runline,total only (add team_total if you want)
# RUNDOWN_RETAIL_GAME_LINE_TYPES="moneyline,runline,total"
# Core markets when unset: 1,2,3 (ML/Spread/Total). Player prop IDs are merged automatically from the catalog API.
# RUNDOWN_MARKET_IDS="1,2,3"
# Extra IDs to always request (comma-separated)
# RUNDOWN_EXTRA_MARKET_IDS=""
# false = only use RUNDOWN_MARKET_IDS without auto-merging proposition markets from /sports/{id}/markets/{date}
RUNDOWN_DISCOVER_PROP_MARKET_IDS="true"
# Cap merged market_ids length (API / URL limits)
RUNDOWN_MAX_MARKET_IDS="56"
# Eastern date boundary for “today’s board” (minutes offset per Rundown docs; 300 ≈ US Eastern)
RUNDOWN_DATE_OFFSET_MINUTES="300"
# Server cache for therundown.io requests (seconds). Default 900 (15m) to reduce HTTP 429 bursts; try 1800–3600 under heavy traffic.
# RUNDOWN_FETCH_REVALIDATE_SECONDS="900"
# Milliseconds between extra prop batch calls to Rundown (reduces burst 429s). Default 700.
# RUNDOWN_BATCH_DELAY_MS="900"
# ODDS_PROVIDER="rundown"
# With rundown, player props are rebuilt from affiliate lines using the same JSON shape as The Odds API (no Odds key required for props).
